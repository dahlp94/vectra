# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Database (matches docker-compose defaults; override for other hosts) ---
POSTGRES_USER=vectra
POSTGRES_PASSWORD=vectra
POSTGRES_DB=vectra
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy URL (sync driver for Week 1)
DATABASE_URL=postgresql+psycopg2://vectra:vectra@localhost:5432/vectra

# --- Embeddings (provider + model; keys added when you wire the provider) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=
